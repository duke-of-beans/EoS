/**
 * Purpose: Computes composite project risk score
 * Dependencies: Node.js std lib
 * API: SauronRiskScorer().compute(scanReport, dependencyAudit)
 */

export class SauronRiskScorer {
  constructor(config = {}) {
    // Default weights for different risk components
    this.weights = {
      issues: 0.4,
      cves: 0.4,
      licenses: 0.2,
      ...config.weights
    };

    // Severity weights for issue scoring
    this.severityWeights = {
      critical: 10,
      high: 5,
      medium: 2,
      low: 1,
      info: 0.1,
      ...config.severityWeights
    };

    // CVE severity weights
    this.cveWeights = {
      critical: 15,
      high: 8,
      medium: 3,
      low: 1,
      ...config.cveWeights
    };

    // License risk weights
    this.licenseWeights = {
      'GPL-3.0': 8,
      'GPL-2.0': 8,
      'AGPL-3.0': 10,
      'UNKNOWN': 5,
      'UNLICENSED': 7,
      ...config.licenseWeights
    };

    this.normalize = config.normalize !== undefined ? config.normalize : true;
    this.previousScore = config.previousScore || null;
  }

  /**
   * Compute composite risk score from scan report and dependency audit
   * @param {Object} scanReport - Scan report with issues array
   * @param {Object} dependencyAudit - Dependency audit with vulnerabilities and licenses
   * @returns {Object} Risk score with components and category
   */
  compute(scanReport, dependencyAudit) {
    try {
      // Calculate individual component scores
      const issuesScore = this._calculateIssueScore(scanReport);
      const cvesScore = this._calculateCVEScore(dependencyAudit);
      const licensesScore = this._calculateLicenseScore(dependencyAudit);

      // Apply weights to compute raw total
      const rawTotal = 
        (issuesScore * this.weights.issues) +
        (cvesScore * this.weights.cves) +
        (licensesScore * this.weights.licenses);

      // Normalize to 0-100 scale if enabled
      let totalScore = rawTotal;
      if (this.normalize) {
        totalScore = Math.min(100, Math.max(0, rawTotal));
      }

      // Determine risk category
      const category = this._getRiskCategory(totalScore);

      // Calculate trend if previous score available
      const trend = this.previousScore !== null
        ? {
            delta: totalScore - this.previousScore,
            direction: totalScore > this.previousScore ? 'increasing' : 
                      totalScore < this.previousScore ? 'decreasing' : 'stable'
          }
        : null;

      return {
        totalScore: Math.round(totalScore * 100) / 100,
        components: {
          issues: Math.round(issuesScore * 100) / 100,
          cves: Math.round(cvesScore * 100) / 100,
          licenses: Math.round(licensesScore * 100) / 100
        },
        normalized: this.normalize,
        category,
        ...(trend && { trend })
      };
    } catch (error) {
      // Return safe default on any error
      return {
        totalScore: 0,
        components: {
          issues: 0,
          cves: 0,
          licenses: 0
        },
        normalized: this.normalize,
        category: 'unknown',
        error: error.message
      };
    }
  }

  /**
   * Calculate score based on issue severity distribution
   * @private
   */
  _calculateIssueScore(scanReport) {
    if (!scanReport || !scanReport.issues || !Array.isArray(scanReport.issues)) {
      return 0;
    }

    // Count issues by severity
    const severityCounts = scanReport.issues.reduce((acc, issue) => {
      const severity = (issue.severity || 'info').toLowerCase();
      acc[severity] = (acc[severity] || 0) + 1;
      return acc;
    }, {});

    // Calculate weighted score
    let score = 0;
    for (const [severity, count] of Object.entries(severityCounts)) {
      score += count * (this.severityWeights[severity] || 0.1);
    }

    // Apply logarithmic scaling to prevent runaway scores
    return Math.log10(score + 1) * 20;
  }

  /**
   * Calculate score based on CVE presence in dependencies
   * @private
   */
  _calculateCVEScore(dependencyAudit) {
    if (!dependencyAudit || !dependencyAudit.vulnerabilities) {
      return 0;
    }

    let score = 0;
    const vulns = dependencyAudit.vulnerabilities;

    // Handle different audit formats
    if (Array.isArray(vulns)) {
      // Array of vulnerability objects
      vulns.forEach(vuln => {
        const severity = (vuln.severity || 'low').toLowerCase();
        score += this.cveWeights[severity] || 1;
      });
    } else if (typeof vulns === 'object') {
      // Severity counts object
      for (const [severity, count] of Object.entries(vulns)) {
        if (typeof count === 'number') {
          score += count * (this.cveWeights[severity.toLowerCase()] || 1);
        }
      }
    }

    // Apply logarithmic scaling
    return Math.log10(score + 1) * 15;
  }

  /**
   * Calculate score based on license compliance
   * @private
   */
  _calculateLicenseScore(dependencyAudit) {
    if (!dependencyAudit || !dependencyAudit.dependencies) {
      return 0;
    }

    let score = 0;
    const deps = dependencyAudit.dependencies;

    // Handle different dependency formats
    if (Array.isArray(deps)) {
      deps.forEach(dep => {
        const license = dep.license || 'UNKNOWN';
        score += this.licenseWeights[license] || 0;
      });
    } else if (typeof deps === 'object') {
      for (const [depName, depInfo] of Object.entries(deps)) {
        if (depInfo && typeof depInfo === 'object') {
          const license = depInfo.license || 'UNKNOWN';
          score += this.licenseWeights[license] || 0;
        }
      }
    }

    // Scale based on number of dependencies
    const depCount = Array.isArray(deps) ? deps.length : Object.keys(deps).length;
    return depCount > 0 ? (score / depCount) * 10 : 0;
  }

  /**
   * Determine risk category based on total score
   * @private
   */
  _getRiskCategory(score) {
    if (score >= 80) return 'critical';
    if (score >= 60) return 'high';
    if (score >= 40) return 'medium';
    if (score >= 20) return 'low';
    return 'minimal';
  }
}
export default SauronRiskScorer;

