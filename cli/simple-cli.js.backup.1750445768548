#!/usr/bin/env node

/**
 * Purpose: Auto-generated working CLI for Eye of Sauron
 * Import path: ./core/EyeOfSauronOmniscient.js
 * Generated by: import-fix-combined.js
 */

import { promises as fs } from 'fs';
import path from 'path';
import { fileURLToPath } from 'url';

// Import the scanner using tested working path
import { createEye } from './core/EyeOfSauronOmniscient.js';

const __filename = fileURLToPath(import.meta.url);
const __dirname = path.dirname(__filename);

function parseArgs() {
  const args = process.argv.slice(2);
  const options = { path: '.', mode: 'deep', output: null, help: false };

  for (let i = 0; i < args.length; i++) {
    const arg = args[i];
    if (arg === '--help' || arg === '-h') options.help = true;
    else if (arg === '--path' || arg === '-p') options.path = args[++i] || '.';
    else if (arg === '--mode' || arg === '-m') options.mode = args[++i] || 'deep';
    else if (arg === '--output' || arg === '-o') options.output = args[++i];
  }
  return options;
}

function showHelp() {
  console.log(`
🔍 Eye of Sauron Scanner CLI

Usage: node cli/simple-cli.js [options]

Options:
  --path, -p <path>      Path to scan (default: .)
  --mode, -m <mode>      Scan mode: quick|deep|quantum (default: deep)
  --output, -o <file>    Output file for results
  --help, -h            Show this help

Examples:
  node cli/simple-cli.js --path ./src --mode deep
  node cli/simple-cli.js --path . --output results.json
`);
}

async function runScan(options) {
  try {
    console.log('🔍 Eye of Sauron Scanner');
    console.log(`📁 Scanning: ${options.path}`);
    console.log(`⚙️  Mode: ${options.mode}`);
    console.log('');

    // Check path exists
    const scanPath = path.resolve(options.path);
    try {
      await fs.access(scanPath);
    } catch (error) {
      console.error(`❌ Path not found: ${scanPath}`);
      process.exit(1);
    }

    // Create scanner
    console.log('⏳ Initializing scanner...');
    const scanner = createEye();
    console.log('✅ Scanner ready');

    // Run scan
    console.log('⏳ Scanning (debug messages normal)...');
    const startTime = Date.now();
    const results = await scanner.scan(scanPath, options.mode);
    const duration = ((Date.now() - startTime) / 1000).toFixed(2);

    // Show results
    console.log('\n📊 Scan Results:');
    console.log('═'.repeat(50));
    
    if (results?.summary) {
      console.log(`📊 Files: ${results.summary.filesScanned || 0}`);
      console.log(`🚨 Issues: ${results.summary.totalIssues || 0}`);
      
      if (results.summary.issuesBySeverity) {
        Object.entries(results.summary.issuesBySeverity).forEach(([sev, count]) => {
          if (count > 0) {
            const icon = sev === 'CRITICAL' ? '🔴' : sev === 'WARNING' ? '🟡' : '🔵';
            console.log(`  ${icon} ${sev}: ${count}`);
          }
        });
      }
    }

    // Show top files with issues
    if (results?.files) {
      const filesWithIssues = Object.entries(results.files)
        .filter(([_, data]) => data.issues?.length > 0)
        .sort(([_, a], [__, b]) => (b.issues?.length || 0) - (a.issues?.length || 0));
      
      if (filesWithIssues.length > 0) {
        console.log('\n📂 Top Files with Issues:');
        filesWithIssues.slice(0, 3).forEach(([file, data]) => {
          const rel = path.relative(process.cwd(), file);
          console.log(`  📄 ${rel} (${data.issues.length} issues)`);
        });
        if (filesWithIssues.length > 3) {
          console.log(`  ... and ${filesWithIssues.length - 3} more files`);
        }
      } else {
        console.log('\n🎉 No issues found!');
      }
    }

    // Save if requested
    if (options.output) {
      await fs.writeFile(options.output, JSON.stringify(results, null, 2));
      console.log(`\n💾 Saved: ${options.output}`);
    }

    console.log(`\n✅ Completed in ${duration}s`);
    process.exit(results?.summary?.totalIssues > 0 ? 1 : 0);

  } catch (error) {
    console.error('\n❌ Scan failed:', error.message);
    if (process.env.DEBUG) console.error(error.stack);
    process.exit(1);
  }
}

async function main() {
  const options = parseArgs();
  if (options.help) {
    showHelp();
    process.exit(0);
  }
  await runScan(options);
}

main().catch(error => {
  console.error('Fatal error:', error.message);
  process.exit(1);
});