#!/usr/bin/env node

/**
 * Purpose: Simple CLI for Eye of Sauron scanner - Quick scanning interface
 * Dependencies: Node.js std lib (fs, path), EyeOfSauronOmniscient
 * Public API: Command-line executable only
 * 
 * A lightweight CLI interface for the Eye of Sauron scanning system.
 * Processes command-line arguments and executes scans with proper result handling.
 */

import { promises as fs } from 'fs';
import path from 'path';
import { fileURLToPath } from 'url';

// Import Eye of Sauron components - using both named and default imports
import EyeOfSauronOmniscient, { createEye } from '../core/EyeOfSauronOmniscient.js';

const __filename = fileURLToPath(import.meta.url);
const __dirname = path.dirname(__filename);

/**
 * Parse command line arguments
 * @returns {object} Parsed arguments
 */
function parseArgs() {
  const args = process.argv.slice(2);
  const options = {
    path: '.',
    mode: 'deep',
    output: null,
    help: false
  };

  for (let i = 0; i < args.length; i++) {
    const arg = args[i];
    
    if (arg === '--help' || arg === '-h') {
      options.help = true;
    } else if (arg === '--path' || arg === '-p') {
      options.path = args[++i] || '.';
    } else if (arg === '--mode' || arg === '-m') {
      options.mode = args[++i] || 'deep';
    } else if (arg === '--output' || arg === '-o') {
      options.output = args[++i];
    }
  }

  return options;
}

/**
 * Show help information
 */
function showHelp() {
  console.log(`
🔍 Eye of Sauron Simple CLI

Usage: node simple-cli.js [options]

Options:
  --path, -p <path>      Path to scan (default: .)
  --mode, -m <mode>      Scan mode: quick|deep|quantum (default: deep)
  --output, -o <file>    Output file for results (default: console only)
  --help, -h            Show this help

Examples:
  node simple-cli.js --path ./src --mode deep
  node simple-cli.js --path . --output scan-results.json
  node simple-cli.js --path ./components --mode quick
`);
}

/**
 * Main scan function
 * @param {object} options - CLI options
 */
async function runScan(options) {
  try {
    console.log('🔍 Eye of Sauron Simple Scanner');
    console.log(`📁 Scanning path: ${options.path}`);
    console.log(`⚙️  Mode: ${options.mode}`);
    console.log('');

    // Initialize scanner - try both import methods
    let scanner;
    try {
      // Try using createEye function if available
      scanner = typeof createEye === 'function' ? createEye() : new EyeOfSauronOmniscient();
    } catch (error) {
      console.log('⚠️  Trying alternative initialization...');
      scanner = EyeOfSauronOmniscient.default ? new EyeOfSauronOmniscient.default() : new EyeOfSauronOmniscient();
    }
    
    // Check if path exists
    const scanPath = path.resolve(options.path);
    try {
      await fs.access(scanPath);
    } catch (error) {
      console.error(`❌ Error: Path '${scanPath}' does not exist or is not accessible`);
      process.exit(1);
    }

    // Execute scan
    console.log('⏳ Starting scan...');
    const startTime = Date.now();
    
    // Try different scan method names
    let results;
    if (typeof scanner.scan === 'function') {
      results = await scanner.scan(scanPath, options.mode);
    } else if (typeof scanner.scanPath === 'function') {
      results = await scanner.scanPath(scanPath, options.mode);
    } else {
      throw new Error('Scanner does not have a scan() or scanPath() method');
    }
    
    const duration = ((Date.now() - startTime) / 1000).toFixed(2);
    
    // Process results correctly
    console.log('\n📊 Scan Results:');
    console.log('═'.repeat(50));
    
    // Handle different result structures
    if (results) {
      // Check for summary in different locations
      const summary = results.summary || results.report?.summary || {};
      
      console.log(`📊 Files scanned: ${summary.filesScanned || 'Unknown'}`);
      console.log(`🚨 Total issues: ${summary.totalIssues || 'Unknown'}`);
      
      if (summary.totalIssues > 0) {
        console.log('\n📋 Issues by severity:');
        const severityData = summary.issuesBySeverity || summary.bySeverity || {};
        Object.entries(severityData).forEach(([severity, count]) => {
          if (count > 0) {
            const icon = severity === 'CRITICAL' ? '🔴' : severity === 'WARNING' ? '🟡' : '🔵';
            console.log(`  ${icon} ${severity}: ${count}`);
          }
        });
      }
      
      // Show detailed file results if available
      const files = results.files || results.report?.files || results.vision?.files || {};
      
      if (Object.keys(files).length > 0) {
        console.log('\n📂 File Details:');
        console.log('-'.repeat(50));
        
        Object.entries(files).forEach(([filePath, fileData]) => {
          if (fileData.issues && fileData.issues.length > 0) {
            const relativePath = path.relative(process.cwd(), filePath);
            console.log(`\n📄 ${relativePath} (${fileData.issues.length} issues):`);
            
            fileData.issues.slice(0, 5).forEach((issue, idx) => {
              const severity = issue.severity || 'INFO';
              const type = issue.type || 'unknown';
              const message = issue.message || 'No description';
              const line = issue.line ? `:${issue.line}` : '';
              
              console.log(`  ${idx + 1}. [${severity}] ${type}${line} - ${message}`);
            });
            
            if (fileData.issues.length > 5) {
              console.log(`  ... and ${fileData.issues.length - 5} more issues`);
            }
          }
        });
      }
    } else {
      console.log('❌ No results returned from scanner');
    }

    // Save to file if requested
    if (options.output) {
      const outputPath = path.resolve(options.output);
      await fs.writeFile(outputPath, JSON.stringify(results, null, 2));
      console.log(`\n💾 Results saved to: ${outputPath}`);
    }

    console.log(`\n✅ Scan completed in ${duration}s`);
    
    // Exit with appropriate code
    const totalIssues = results?.summary?.totalIssues || results?.report?.summary?.totalIssues || 0;
    const hasIssues = totalIssues > 0;
    process.exit(hasIssues ? 1 : 0);
    
  } catch (error) {
    console.error('❌ Scan failed:');
    console.error(`   ${error.message}`);
    if (error.stack && process.env.DEBUG) {
      console.error('\nStack trace:');
      console.error(error.stack);
    }
    console.error('\n🔧 Debug info:');
    console.error(`   Scanner type: ${typeof scanner}`);
    console.error(`   Scanner methods: ${scanner ? Object.getOwnPropertyNames(Object.getPrototypeOf(scanner)).join(', ') : 'N/A'}`);
    process.exit(1);
  }
}

// Main execution
async function main() {
  const options = parseArgs();
  
  if (options.help) {
    showHelp();
    process.exit(0);
  }
  
  await runScan(options);
}

// Execute if run directly
if (import.meta.url === `file://${process.argv[1]}`) {
  main().catch(error => {
    console.error('Fatal error:', error.message);
    process.exit(1);
  });
}

export default { runScan, parseArgs, showHelp };